# ==============================================================================
# Mustang Sage - Environment Variables
# ==============================================================================

# --- Application Mode ---
# Sets the application's operational mode.
# Options: "production", "demo"
# In "demo" mode, the app will use the demo CSV file and mock external APIs.
APP_MODE=production

# --- Microsoft Teams Bot ---
MICROSOFT_APP_ID=your_microsoft_app_id_here
MICROSOFT_APP_PASSWORD=your_microsoft_app_password_here

# --- Slack Bot ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# --- LLM Provider API Keys ---
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- AWS S3 Configuration (for S3 vector store) ---
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION_NAME=us-west-2

# --- Other Services ---
GOOGLE_MAPS_API_KEY=your_maps_api_key_here
SHOPVOX_API_KEY=your_shopvox_key_here
AUDIT_API_KEY=your_super_secret_audit_key

# --- Database ---
NEON_DATABASE_URL=postgresql://user:pass@host:5432/db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mustang_whisper
POSTGRES_HOST=localhost

# --- Telemetry (Optional) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Email Alerts for System Failures ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SENDER_EMAIL=noreply@example.com
