# LLM Orchestration
LLM_PROVIDER=gemini # options: gemini, openai, anthropic
EMBEDDER_PROVIDER=gemini # options: gemini, openai
ENABLE_NEW_AGENTS=false # Safe fallback rollback logic

# API Keys
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MAPS_API_KEY=your_maps_api_key_here # Optional: Triggers mock routing if omitted
SHOPVOX_API_KEY=your_shopvox_key_here
AUDIT_API_KEY=your_super_secret_audit_key # Enforces security on scheduled maintenance endpoints

# Neon DB Vectors
NEON_DATABASE_URL=postgresql://user:pass@host:5432/db

# Database (PostgreSQL) – used by the `db` service or Neon fallback
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mustang_whisper
POSTGRES_HOST=localhost   # for local dev; Neon overrides via NEON_DATABASE_URL

# Optional Redis broker (used by background workers, if any)
REDIS_URL=redis://redis:6379/0
